{
  "name": "nuxt-rendering-performance-comparison",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "unlighthouse:local": "unlighthouse",
    "unlighthouse:prod": "NODE_ENV=PROD unlighthouse",
    "lh:clean:tbt": "rm -f ./reports/tbt/*",
    "lh:clean:lcp": "rm -f ./reports/lcp/*",
    "lh:clean:si": "rm -f ./reports/si/*",
    "lh:tbt": "pnpm run lh:clean:tbt && cross-env BASE_URL=http://localhost:3000 LH_METRIC=tbt lhci collect && LH_METRIC=tbt lhci upload && pnpm run lh:metrics:tbt",
    "lh:lcp": "pnpm run lh:clean:lcp && cross-env BASE_URL=http://localhost:3000 LH_METRIC=lcp lhci collect && LH_METRIC=lcp lhci upload && pnpm run lh:metrics:lcp",
    "lh:si": "pnpm run lh:clean:si && cross-env BASE_URL=http://localhost:3000 LH_METRIC=si lhci collect && LH_METRIC=si lhci upload && pnpm run lh:metrics:si",
    "lh:metrics:tbt": "cross-env LH_METRIC=tbt node scripts/collect-metrics.js",
    "lh:metrics:lcp": "cross-env LH_METRIC=lcp node scripts/collect-metrics.js",
    "lh:metrics:si": "cross-env LH_METRIC=si node scripts/collect-metrics.js"
  },
  "dependencies": {
    "@nuxt/eslint": "1.12.1",
    "@picocss/pico": "^2.1.1",
    "@sentry/nuxt": "^10",
    "eslint": "^9.39.2",
    "import-in-the-middle": "^3.0.0",
    "nuxt": "^3.20.2",
    "typescript": "^5.9.3",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "pnpm": {
    "overrides": {
      "@vercel/nft": "^0.27.4"
    }
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "cross-env": "^10.1.0",
    "unlighthouse": "^0.17.7"
  }
}
